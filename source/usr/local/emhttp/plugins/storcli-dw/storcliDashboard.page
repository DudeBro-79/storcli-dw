<script type="text/javascript">
function updateStorCLIDashboard() {
    $.get('/plugins/storcli-dw/include/storcli_status.php', function(data) {
        if (data && data.success) {
            var d = data.success;

            var tempClass = d.temp_class || '';
            var tempText  = (d.temp !== null) ? d.temp + ' \u00b0C' : '\u2014';
            var tempLabel = d.temp_label ? ' <em>' + d.temp_label + '</em>' : '';
            $("#tblStorCLIDash .storcli-roc-temp").html("<span class='" + tempClass + "'>" + tempText + tempLabel + "</span>");
            $("#tblStorCLIDash .storcli-temp-header").html("<span class='" + tempClass + "'>" + tempText + "</span>");

            $("#tblStorCLIDash .storcli-ctrl-model").html(d.model || '\u2014');

            var pdClass = (d.pd_count > 0) ? 'green-text' : 'orange-text';
            var pdText  = (d.pd_count !== null) ? d.pd_count + ' drives detected' : '\u2014';
            $("#tblStorCLIDash .storcli-pd-count").html("<span class='" + pdClass + "'>" + pdText + "</span>");

            var stateClass = (d.ctrl_state === 'Optimal') ? 'green-text' : 'orange-text';
            $("#tblStorCLIDash .storcli-ctrl-state").html("<span class='" + stateClass + "'>" + (d.ctrl_state || '\u2014') + "</span>");
            $("#tblStorCLIDash .storcli-status-header").html("<span class='" + stateClass + "'>" + (d.ctrl_state || '\u2014') + "</span>");

            if (d.alert) {
                $("#tblStorCLIDash .storcli-alert-msg").text(d.alert);
                $("#storcli-alert-row").show();
            } else {
                $("#storcli-alert-row").hide();
            }

        } else {
            var errHtml = "<i class='red-text fa fa-times-circle'></i> <em>Error (check logs)</em>";
            $("#tblStorCLIDash .storcli-roc-temp").html(errHtml);
            $("#tblStorCLIDash .storcli-ctrl-model").html(errHtml);
            $("#tblStorCLIDash .storcli-pd-count").html(errHtml);
            $("#tblStorCLIDash .storcli-ctrl-state").html(errHtml);
            $("#tblStorCLIDash .storcli-temp-header").html("<i class='red-text fa fa-times-circle'></i>");
            $("#tblStorCLIDash .storcli-status-header").html("<i class='red-text fa fa-times-circle'></i>");
        }
    }, 'json');

    clearTimeout(timers.updateStorCLIDashboard);
    timers.updateStorCLIDashboard = setTimeout(updateStorCLIDashboard, 30000);
}

$(function() {
    updateStorCLIDashboard();
});
</script>
